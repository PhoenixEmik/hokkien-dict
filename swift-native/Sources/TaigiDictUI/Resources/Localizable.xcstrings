    "referenceHanjiRecommendedP1" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The dictionary generally follows the Ministry of Education recommended Taiwanese Hokkien characters while balancing readability, sound-meaning transparency, and everyday usability."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本辞典原则上遵照教育部公告的台湾台语推荐用字成果，并兼顾望字生音义、常用度与阅读便利性。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本辭典原則上遵照教育部公告的臺灣台語推薦用字成果，並兼顧望字生音義、常用度與閱讀便利性。"
          }
        }
      }
    },
    "referenceHanjiSubstituteRow1Value" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When the original character is too rare or opaque, the dictionary may switch to a more familiar substitute."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "当本字过于艰深冷僻时，辞典会改用较常见、较容易理解的替代字。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "當本字過於艱深冷僻時，辭典會改用較常見、較容易理解的替代字。"
          }
        }
      }
    },
    "referenceHanjiSubstituteRow2Value" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Highly familiar basic characters may be preferred when they reduce reading friction for most users."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "若标准语的常用基本字更便于理解，辞典可能优先采用，以降低阅读负担。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "若標準語的常用基本字更便於理解，辭典可能優先採用，以降低閱讀負擔。"
          }
        }
      }
    },
    "referenceHanjiSubstituteRow3Value" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Established colloquial forms can remain in use when they are already widespread and stable in community writing."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "若俗字已经广泛约定俗成，且实际使用稳定，辞典会保留这类写法。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "若俗字已經廣泛約定俗成，且實際使用穩定，辭典會保留這類寫法。"
          }
        }
      }
    },
