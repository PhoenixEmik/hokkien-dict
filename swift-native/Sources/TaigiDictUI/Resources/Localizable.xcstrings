      }
    },
    "referenceTaiLoB2" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The dictionary writes citation tones, not the surface sandhi tones heard inside longer phrases."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "辞典标注的是本调，不是词句连读时实际听到的变调。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "辭典標注的是本調，不是詞句連讀時實際聽到的變調。"
          }
        }
      }
    },
    "referenceTaiLoB3" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Some accents fall outside the basic seven tones, including a sixth tone in certain dialects and a ninth tone in contracted syllables."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "部分地方腔仍可见第 6 声；合音或三连音的首音节也可能出现第 9 声。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "部分地方腔仍可見第 6 聲；合音或三連音的首音節也可能出現第 9 聲。"
          }
        }
      }
    },
    "referenceTaiLoB4" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Neutral tone is marked with -- between the stressed and light syllables."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "轻声以 -- 标在重读音节与轻声音节之间，表示后接音节为轻读。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "輕聲以 -- 標在重讀音節與輕聲音節之間，表示後接音節為輕讀。"
          }
        }
      }
    },
    "referenceTaiLoB5" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tone sandhi changes with phrasing, so the dictionary keeps the base citation tone unless a form has no citation reading."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "变调会随断句改变，因此本辞典原则上标本调；只有没有本调的读法才例外处理。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "變調會隨斷句改變，因此本辭典原則上標本調；只有沒有本調的讀法才例外處理。"
          }
        }
      }
    },
    "referenceTaiLoB6" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Main sandhi rules include 1→7, 2→1, 3→2, 4→8 or 2, 5→7 or 3, 7→3, and 8→4 or 3 depending on the coda."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "主流变调规则大致为 1→7、2→1、3→2、4→8 或 2、5→7 或 3、7→3、8→4 或 3，依韵尾与腔口而异。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "主流變調規則大致為 1→7、2→1、3→2、4→8 或 2、5→7 或 3、7→3、8→4 或 3，依韻尾與腔口而異。"
          }
        }
      }
    },
    "referenceTaiLoNeutralExample1" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "āu--ji̍t (後--日)"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "āu--ji̍t（後--日）"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "āu--ji̍t（後--日）"
          }
        }
      }
    },
    "referenceTaiLoNeutralExample2" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "tsáu--tshut-khì (走--出去)"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "tsáu--tshut-khì（走--出去）"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "tsáu--tshut-khì（走--出去）"
          }
        }
      }
    },
    "referenceTaiLoNeutralExample3" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Common neutral-tone particles include --lah, --aih, --ooh, and --ah."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "常见轻声语助词如 --lah、--aih、--ooh、--ah。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "常見輕聲語助詞如 --lah、--aih、--ooh、--ah。"
          }
        }
      }
    },
    "referenceTaiLoSandhiRow1Value" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "sim-kuann becomes sīm-kuann in phrase reading."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如心肝 sim-kuann 在连读时会读成 sīm-kuann。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如心肝 sim-kuann 在連讀時會讀成 sīm-kuann。"
          }
        }
      }
    },
    "referenceTaiLoSandhiRow2Value" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "sió-tī becomes sio-tī inside a phrase."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如小弟 sió-tī 在词组中会变成 sio-tī。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如小弟 sió-tī 在詞組中會變成 sio-tī。"
          }
        }
      }
    },
    "referenceTaiLoSandhiRow3Value" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "sè-kan becomes sé-kan in connected speech."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如世间 sè-kan 在连读时会读成 sé-kan。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如世間 sè-kan 在連讀時會讀成 sé-kan。"
          }
        }
      }
    },
    "referenceTaiLoSandhiRow4Value" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "guā-kháu becomes guà-kháu in connected speech."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如外口 guā-kháu 在连读时会读成 guà-kháu。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如外口 guā-kháu 在連讀時會讀成 guà-kháu。"
          }
        }
      }
    },
    "referenceTaiLoToneRow1Value" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yin-ping, yin-shang, yin-qu, and yin-ru."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "对应阴平、阴上、阴去、阴入。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "對應陰平、陰上、陰去、陰入。"
          }
        }
      }
    },
    "referenceTaiLoToneRow2Value" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yang-ping, yang-qu, and yang-ru."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "对应阳平、阳去、阳入。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "對應陽平、陽去、陽入。"
          }
        }
      }
    },
    "referenceTaiLoP1" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The dictionary adopts the Ministry of Education Taiwanese Romanization System (Tai-Lo) announced in 2006 and writes borrowed words by their reconstructed citation tones."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本辞典采用教育部公告的台湾台语罗马字拼音方案（台罗），外来词则依台语词目回推本调后标注。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本辭典採用教育部公告的臺灣台語羅馬字拼音方案（臺羅），外來詞則依台語詞目回推本調後標注。"
          }
        }
      }
    },
    "referenceTaiLoP2" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Besides the basic citation tones, Tai-Lo also describes special tone marks, neutral tone with --, and predictable tone sandhi inside phrases."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "除了本调之外，台罗也说明特殊声调、以 -- 标示的轻声，以及词句中的连读变调。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "除了本調之外，臺羅也說明特殊聲調、以 -- 標示的輕聲，以及詞句中的連讀變調。"
          }
        }
      }
    },
