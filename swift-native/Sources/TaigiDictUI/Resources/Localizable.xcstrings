    "referenceHanjiB1" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Taiwanese Hokkien and Mandarin differ in sound, vocabulary, and syntax, so Hanji choice requires dedicated rules."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "台湾台语与华语在语音、词汇、句法上差异明显，因此汉字书写需要独立的选字原则。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "臺灣台語與華語在語音、詞彙、句法上差異明顯，因此漢字書寫需要獨立的選字原則。"
          }
        }
      }
    },
    "referenceHanjiB2" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Benzi: use an inherited Han character with a cognate meaning, such as 芳 for phang and 細 for sè."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本字：优先采用传统文献中已有、且与词义同源的汉字，如 phang 写作【芳】、sè 写作【细】。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本字：優先採用傳統文獻中已有、且與詞義同源的漢字，如 phang 寫作【芳】、sè 寫作【細】。"
          }
        }
      }
    },
    "referenceHanjiB3" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Semantic loan characters: borrow the meaning of a familiar character, such as 人 read as lâng."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "训用字：借义不借音，采用熟悉字形表达词义，例如【人】可读 lâng。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "訓用字：借義不借音，採用熟悉字形表達詞義，例如【人】可讀 lâng。"
          }
        }
      }
    },
    "referenceHanjiB4" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Common colloquial, phonetic, or newly created characters remain acceptable when no stable Benzi exists."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "俗字、借音字与新造字，在没有稳定本字时仍可采用，如【某】、【𬦰】、【躼】。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "俗字、借音字與新造字，在沒有穩定本字時仍可採用，如【某】、【𬦰】、【躼】。"
          }
        }
      }
    },
    "referenceHanjiB5" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When choosing substitute characters, the dictionary balances readability, standard-language familiarity, and well-established community usage."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "替代字的选择会综合考虑字形是否艰深、是否与标准语常用字重叠，以及民间是否早已约定俗成。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "替代字的選擇會綜合考慮字形是否艱深、是否與標準語常用字重疊，以及民間是否早已約定俗成。"
          }
        }
      }
    },
    "referenceHanjiP1" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hanji usage in Taiwanese Hokkien is more contested than in Mandarin because the languages diverged early and many words do not map neatly to a single inherited character."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "台湾台语的汉字书写问题较华语更复杂，因为两者分支较早，且有不少词汇并非直接源自汉语。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "臺灣台語的漢字書寫問題較華語更複雜，因為兩者分支較早，且有不少詞彙並非直接源自漢語。"
          }
        }
      }
    },
    "referenceHanjiP2" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This dictionary writes Taiwanese Hokkien primarily with Hanji and classifies chosen forms into Benzi, semantic loans, colloquial/phonetic loans, and newly created characters."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本辞典以汉字为基础，并把用字区分为本字、训用字、俗字或借音字，以及新造字等类型。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本辭典以漢字為基礎，並把用字區分為本字、訓用字、俗字或借音字，以及新造字等類型。"
          }
        }
      }
    },
